NODE_ENV=production
PORT=5000
FRONTEND_URL=http://your-prod-ec2-ip:3000
APP_NAME=MyApp-API

# PostgreSQL connection — point this at your RDS/EC2 Postgres instance
DB_HOST=your-prod-db-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=myapp
DB_SSL=true

# JWT — replace with a long random string in real production
JWT_SECRET=change-this-to-a-long-random-string
